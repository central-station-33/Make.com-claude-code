{
  "name": "InRange — Data Pipeline (Ingest → Score → Enrich)",
  "flow": [
    {
      "id": 1,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": { "handleErrors": true, "useNewZLibDecompression": true },
      "mapper": {
        "url": "https://data.cityofnewyork.us/resource/erm2-nwe9.json?$where=complaint_type%20IN%20('UNSANITARY%20CONDITION'%2C'HEAT%2FHOT%20WATER'%2C'PAINT%2FPLASTER'%2C'MOLD'%2C'WATER%20SYSTEM'%2C'BUILDING%20CONDITION'%2C'LEAD'%2C'PLUMBING'%2C'PEST%20CONTROL'%2C'ELEVATOR'%2C'DOOR%2FWINDOW')%26$limit=200%26$order=created_date%20DESC",
        "serializeUrl": false,
        "method": "get",
        "headers": [],
        "qs": [],
        "bodyType": "raw",
        "parseResponse": true,
        "responsetype": "json",
        "timeout": 30000,
        "rejectUnauthorized": true,
        "followRedirect": true
      },
      "metadata": {
        "designer": { "x": -600, "y": 0 },
        "restore": { "parameters": { "handleErrors": { "label": "Yes" } } }
      }
    },
    {
      "id": 2,
      "module": "builtin:BasicIterator",
      "version": 1,
      "parameters": {},
      "mapper": { "array": "{{1.data}}" },
      "metadata": { "designer": { "x": -330, "y": 0 } }
    },
    {
      "id": 3,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": { "handleErrors": true, "useNewZLibDecompression": true },
      "mapper": {
        "url": "https://omzugrtgwsjypekuzgtn.supabase.co/functions/v1/ingest-raw-properties",
        "serializeUrl": false,
        "method": "post",
        "headers": [
          { "name": "Authorization", "value": "Bearer YOUR_SUPABASE_SERVICE_ROLE_KEY" },
          { "name": "Content-Type",  "value": "application/json" }
        ],
        "qs": [],
        "bodyType": "raw",
        "contentType": "application/json",
        "body": "{\"source\":\"nyc_311\",\"raw_data\":{\"address\":\"{{2.value.incident_address}}\",\"city\":\"{{2.value.city}}\",\"state\":\"NY\",\"zip\":\"{{2.value.incident_zip}}\",\"borough\":\"{{2.value.borough}}\",\"complaint_type\":\"{{2.value.complaint_type}}\",\"descriptor\":\"{{2.value.descriptor}}\",\"status\":\"{{2.value.status}}\",\"created_date\":\"{{2.value.created_date}}\",\"closed_date\":\"{{2.value.closed_date}}\",\"bbl\":\"{{2.value.bbl}}\",\"latitude\":\"{{2.value.latitude}}\",\"longitude\":\"{{2.value.longitude}}\"}}",
        "parseResponse": true,
        "responsetype": "json",
        "timeout": 15000,
        "rejectUnauthorized": true,
        "followRedirect": true
      },
      "metadata": { "designer": { "x": -60, "y": 0 } }
    },
    {
      "id": 4,
      "module": "builtin:BasicAggregator",
      "version": 1,
      "parameters": { "feeder": 2 },
      "mapper": { "value": "{{3.statusCode}}" },
      "metadata": { "designer": { "x": 210, "y": 0 } }
    },
    {
      "id": 5,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": { "handleErrors": true, "useNewZLibDecompression": true },
      "mapper": {
        "url": "https://omzugrtgwsjypekuzgtn.supabase.co/functions/v1/process-raw-properties",
        "serializeUrl": false,
        "method": "post",
        "headers": [
          { "name": "Authorization", "value": "Bearer YOUR_SUPABASE_SERVICE_ROLE_KEY" },
          { "name": "Content-Type",  "value": "application/json" }
        ],
        "qs": [],
        "bodyType": "raw",
        "contentType": "application/json",
        "body": "{\"limit\":200}",
        "parseResponse": true,
        "responsetype": "json",
        "timeout": 60000,
        "rejectUnauthorized": true,
        "followRedirect": true
      },
      "metadata": { "designer": { "x": 480, "y": 0 } }
    },
    {
      "id": 6,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": { "handleErrors": true, "useNewZLibDecompression": true },
      "mapper": {
        "url": "https://omzugrtgwsjypekuzgtn.supabase.co/functions/v1/enrich-pending",
        "serializeUrl": false,
        "method": "post",
        "headers": [
          { "name": "Authorization", "value": "Bearer YOUR_SUPABASE_SERVICE_ROLE_KEY" },
          { "name": "Content-Type",  "value": "application/json" }
        ],
        "qs": [],
        "bodyType": "raw",
        "contentType": "application/json",
        "body": "{\"limit\":10}",
        "parseResponse": true,
        "responsetype": "json",
        "timeout": 120000,
        "rejectUnauthorized": true,
        "followRedirect": true
      },
      "metadata": { "designer": { "x": 750, "y": 0 } }
    }
  ],
  "metadata": {
    "instant": false,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": { "orphans": [] },
    "scheduling": {
      "type": "indefinitely",
      "interval": 14400
    }
  }
}
